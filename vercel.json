{
    "installCommand": "bun install",
    "buildCommand": "cd example && bun install && bun run predeploy",
    "outputDirectory": "example/dist",
    "framework": "create-react-app",
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ]
}